---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ThumbnailViewer from "../components/ThumbnailViewer.astro";

const allProjects = await getCollection("projects");
const featured = allProjects.filter((p) => p.data.featured);
---

<BaseLayout title="🍝🍝🍝🍝" backgroundColour="#000000">
  <div class="container">
    <ThumbnailViewer />
    <div class="links">
      <p>Graham Paterson is designer with a strong interest in technology</p>
    </div>
  </div>
</BaseLayout>

<script>
  const links = document.querySelector(".links");
  const viewer = document.querySelector<HTMLElement>("#viewer");
  links?.addEventListener("mouseenter", () =>
    viewer?.style.setProperty("opacity", "0.3"),
  );
  links?.addEventListener("mouseleave", () =>
    viewer?.style.setProperty("opacity", "1"),
  );
</script>

<style>
  body {
    transition: background-color 2000ms linear;
  }
  .container {
    position: relative;
    width: 100vw;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow-y: scroll;
  }

  .links {
    font-family: var(--font-serif);
    line-height: 0.9em;
    letter-spacing: -0.025em;
    color: #ffffff;
    font-size: 80px;
    text-align: center;
    margin: 0 25%;
    z-index: 10;
  }
</style>
