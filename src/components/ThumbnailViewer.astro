<div id="viewer">
  <img id="current-image" src="" />
  <video loop id="current-video" playsinline>
    <source src="" type="video/webm" id="vid-source" />
  </video>
</div>

<script>
  import { initScript } from "../scripts/thumbnails.ts";
  initScript();
</script>

<style>
  #viewer {
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: black;
    transition: opacity 300ms ease;
  }

  @media (hover: none) {
    #viewer {
      opacity: 0.65;
    }
  }

  #current-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #current-video {
    display: none;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
